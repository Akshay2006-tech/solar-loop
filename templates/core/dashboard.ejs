<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
        <h1 style="color: #4a7c2c; margin: 0;">Welcome, <%= user.username %>!</h1>
    </div>
    
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;">
        <div class="stat-card">
            <h3><%= total_panels %></h3>
            <p>Total Panels</p>
        </div>
        <div class="stat-card safe">
            <h3><%= safe_count %></h3>
            <p>Safe</p>
        </div>
        <div class="stat-card warning">
            <h3><%= near_expiry_count %></h3>
            <p>Near Expiry</p>
        </div>
        <div class="stat-card danger">
            <h3><%= expired_count %></h3>
            <p>Expired</p>
        </div>
    </div>

    <div class="card">
        <div style="display: flex; justify-content: space-between; align-items: center;">
            <h2>Your Solar Panels</h2>
            <a href="/add-panel" class="btn btn-success">+ Add Panel</a>
        </div>
    </div>

    <% if (panels.length > 0) { %>
        <div class="panel-list">
            <% panels.forEach(panel => { %>
            <div class="panel-item" style="background: #fff; border: 1px solid #ddd; border-radius: 12px; padding: 24px; margin-bottom: 16px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); display: flex; justify-content: space-between; align-items: center; transition: transform 0.2s ease, box-shadow 0.2s ease;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='0 6px 16px rgba(0,0,0,0.15)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 4px 8px rgba(0,0,0,0.1)'">
                <div class="panel-info" style="flex: 1;">
                    <h3 style="color: #4a7c2c; margin: 0 0 12px 0; font-size: 1.3em; font-weight: 600;"><%= panel.brand %> - <%= panel.capacity_kw || 0 %>kW</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; color: #555; margin-bottom: 12px;">
                        <p style="margin: 0; font-size: 0.95em;"><strong style="color: #333;">Location:</strong> <%= panel.location %></p>
                        <p style="margin: 0; font-size: 0.95em;"><strong style="color: #333;">Warranty:</strong> <%= panel.warranty_years %> years</p>
                        <p style="margin: 0; font-size: 0.95em;"><strong style="color: #333;">Installed:</strong> <%= panel.installation_date %></p>
                    </div>
                    <% 
                        const now = new Date();
                        const installDate = new Date(panel.installation_date);
                        const years = (now - installDate) / (365.25 * 24 * 60 * 60 * 1000);
                        const remaining = panel.warranty_years - years;
                        const percentage = Math.max(0, Math.min(100, (remaining / panel.warranty_years) * 100));
                        let barColor = '#4CAF50';
                        if (percentage < 20) barColor = '#f44336';
                        else if (percentage < 50) barColor = '#ff9800';
                    %>
                    <div style="margin-top: 8px;">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px;">
                            <span style="font-size: 0.85em; color: #666;">Warranty Life</span>
                            <span style="font-size: 0.85em; color: #666;"><%= Math.max(0, remaining.toFixed(1)) %> years left</span>
                        </div>
                        <div style="width: 100%; height: 8px; background-color: #e0e0e0; border-radius: 4px; overflow: hidden;">
                            <div style="width: <%= percentage %>%; height: 100%; background-color: <%= barColor %>; transition: width 0.3s ease;"></div>
                        </div>
                    </div>
                </div>
                
                <div style="text-align: center; min-width: 120px;">
                    <% 
                        const now2 = new Date();
                        const installDate2 = new Date(panel.installation_date);
                        const years2 = (now2 - installDate2) / (365.25 * 24 * 60 * 60 * 1000);
                        const remaining2 = panel.warranty_years - years2;
                        let status = 'safe';
                        if (remaining2 <= 0) status = 'expired';
                        else if (remaining2 <= 2) status = 'near_expiry';
                    %>
                    <% if (status === 'safe') { %>
                        <span class="badge badge-safe" style="display: block; margin-bottom: 12px; padding: 6px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 500;">Safe</span>
                    <% } else if (status === 'near_expiry') { %>
                        <span class="badge badge-warning" style="display: block; margin-bottom: 12px; padding: 6px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 500;">Near Expiry</span>
                    <% } else { %>
                        <span class="badge badge-danger" style="display: block; margin-bottom: 12px; padding: 6px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 500;">Expired</span>
                    <% } %>
                    <form method="POST" action="/delete-panel/<%= panel.id %>" style="display: inline;">
                        <button type="submit" class="btn btn-danger" style="padding: 8px 16px; border-radius: 6px; font-size: 0.9em;" onclick="return confirm('Delete this panel?')">Delete</button>
                    </form>
                </div>
            </div>
            <% }); %>
        </div>
    <% } else { %>
        <div class="card">
            <p>No solar panels registered yet. <a href="/add-panel">Add your first panel</a></p>
        </div>
    <% } %>

    <% if (total_waste > 0) { %>
    <div class="card">
        <h2>Environmental Impact</h2>
        <p><strong>Total Estimated Waste:</strong> <%= total_waste.toFixed(0) %> kg</p>
        <p>Proper recycling can recover up to 95% of materials including silicon, glass, and metals.</p>
    </div>
    <% } %>
</div>
