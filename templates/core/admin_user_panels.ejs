<div class="container" style="margin-top: 2rem;">
    <h1 style="color: #4a7c2c; margin-bottom: 1rem;">👤 <%= user.username %>'s Panels</h1>
    <p style="color: #666; margin-bottom: 2rem;">Email: <%= user.email %></p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div class="stat-card safe">
            <h3><%= total_panels %></h3>
            <p>Total Panels</p>
        </div>
        <div class="stat-card safe">
            <h3><%= safe_count %></h3>
            <p>Safe</p>
        </div>
        <div class="stat-card warning">
            <h3><%= near_expiry_count %></h3>
            <p>Near Expiry</p>
        </div>
        <div class="stat-card danger">
            <h3><%= expired_count %></h3>
            <p>Expired</p>
        </div>
    </div>
    
    <div class="card">
        <h2 style="color: #4a7c2c; margin-bottom: 1.5rem;">Solar Panels</h2>
        
        <% if (panels.length === 0) { %>
            <p style="text-align: center; color: #666; padding: 2rem;">No panels registered yet.</p>
        <% } else { %>
            <div class="panel-list">
                <% panels.forEach(panel => { 
                    const installDate = new Date(panel.installation_date);
                    const now = new Date();
                    const years = (now - installDate) / (365.25 * 24 * 60 * 60 * 1000);
                    const remaining = (panel.warranty_years || 25) - years;
                    let status = 'safe';
                    let statusText = 'Safe';
                    if (remaining <= 0) {
                        status = 'danger';
                        statusText = 'Expired';
                    } else if (remaining <= 2) {
                        status = 'warning';
                        statusText = 'Near Expiry';
                    }
                %>
                    <div class="panel-item">
                        <div class="panel-info">
                            <h3><%= panel.brand %></h3>
                            <p><strong>Capacity:</strong> <%= (panel.capacity_watts / 1000).toFixed(2) %> kW</p>
                            <p><strong>Location:</strong> <%= panel.location %></p>
                            <p><strong>Installation Date:</strong> <%= installDate.toLocaleDateString() %></p>
                            <p><strong>Warranty:</strong> <%= panel.warranty_years %> years</p>
                            <% if (panel.serial_number) { %>
                                <p><strong>Serial Number:</strong> <%= panel.serial_number %></p>
                            <% } %>
                            <p><strong>Age:</strong> <%= years.toFixed(1) %> years</p>
                            <p><strong>Remaining Life:</strong> <%= Math.max(0, remaining).toFixed(1) %> years</p>
                            <span class="badge badge-<%= status %>"><%= statusText %></span>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>
    
    <div style="margin-top: 2rem;">
        <a href="/admin/dashboard" class="btn" style="background: #6c757d;">← Back to Admin Dashboard</a>
    </div>
</div>
