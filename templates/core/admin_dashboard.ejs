<div class="container" style="margin-top: 2rem;">
    <h1 style="color: #4a7c2c; margin-bottom: 2rem;">🔐 Admin Dashboard</h1>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        <div class="card" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <h3 style="color: white; margin: 0 0 0.5rem 0;">Total Users</h3>
            <p style="font-size: 2.5rem; font-weight: bold; margin: 0;"><%= totalUsers %></p>
        </div>
        
        <div class="card" style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); color: white;">
            <h3 style="color: white; margin: 0 0 0.5rem 0;">Total Panels</h3>
            <p style="font-size: 2.5rem; font-weight: bold; margin: 0;"><%= totalPanels %></p>
        </div>
    </div>
    
    <div class="card">
        <h2 style="color: #4a7c2c; margin-bottom: 1.5rem;">Registered Users</h2>
        
        <div style="overflow-x: auto;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead>
                    <tr style="background: #f8f9fa; border-bottom: 2px solid #4a7c2c;">
                        <th style="padding: 1rem; text-align: left;">Username</th>
                        <th style="padding: 1rem; text-align: left;">Email</th>
                        <th style="padding: 1rem; text-align: left;">Role</th>
                        <th style="padding: 1rem; text-align: left;">Registered</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr style="border-bottom: 1px solid #e0e0e0;">
                            <td style="padding: 1rem;"><%= user.username %></td>
                            <td style="padding: 1rem;"><%= user.email %></td>
                            <td style="padding: 1rem;">
                                <% if (user.isAdmin) { %>
                                    <span style="background: #4a7c2c; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.875rem;">Admin</span>
                                <% } else { %>
                                    <span style="background: #6c757d; color: white; padding: 0.25rem 0.75rem; border-radius: 20px; font-size: 0.875rem;">User</span>
                                <% } %>
                            </td>
                            <td style="padding: 1rem;"><%= new Date(user.created_at).toLocaleDateString() %></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
    
    <div style="margin-top: 2rem;">
        <a href="/dashboard" class="btn" style="background: #6c757d;">← Back to User Dashboard</a>
    </div>
</div>
