<div class="container">
    <div class="card" style="max-width: 600px; margin: 2rem auto;">
        <h2>Register Solar Panel</h2>
        <form method="post">
            <div class="form-group">
                <label>Installation Date</label>
                <input type="date" name="installation_date" required>
            </div>
            <div class="form-group">
                <label>Brand</label>
                <select name="brand" id="brand" required onchange="updateWarranty()">
                    <option value="">Select Brand</option>
                    <option value="Maxeon (SunPower)" data-warranty="40">Maxeon (SunPower's premium panels)</option>
                    <option value="REC Group" data-warranty="25">REC Group</option>
                    <option value="Canadian Solar" data-warranty="30">Canadian Solar</option>
                    <option value="Jinko Solar" data-warranty="30">Jinko Solar</option>
                    <option value="Adani Solar" data-warranty="25">Adani Solar</option>
                </select>
            </div>
            <div class="form-group">
                <label>Capacity (kW)</label>
                <input type="number" step="0.01" name="capacity_kw" required>
            </div>

            <div class="form-group">
                <label>Warranty (Years)</label>
                <input type="number" name="warranty_years" id="warranty_years" value="25" required readonly>
            </div>
            <div class="form-group">
                <label>Location</label>
                <input type="text" name="location" required>
            </div>
            <div class="form-group">
                <label>Serial Number (Optional)</label>
                <input type="text" name="serial_number">
            </div>
            <button type="submit" class="btn btn-success">Register Panel</button>
            <a href="/dashboard" class="btn" style="background: #ccc;">Cancel</a>
        </form>
    </div>
</div>

<script>
function updateWarranty() {
    const brandSelect = document.getElementById('brand');
    const warrantyInput = document.getElementById('warranty_years');
    const selectedOption = brandSelect.options[brandSelect.selectedIndex];
    
    if (selectedOption.dataset.warranty) {
        warrantyInput.value = selectedOption.dataset.warranty;
    } else {
        warrantyInput.value = '25';
    }
}
</script>
